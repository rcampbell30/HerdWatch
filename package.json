{
  "name": "herdwatch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run data:build && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "data:download": "node scripts/download-cover-sources.mjs",
    "data:cover:areas": "python scripts/build-cover-areas.py",
    "data:cover:trends": "python scripts/build-cover-trends.py",
    "data:cover:all": "npm run data:download && npm run data:cover:areas && npm run data:cover:trends && npm run data:build",
    "data:build": "node scripts/build-data.mjs",
    "data:validate": "node scripts/build-data.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
